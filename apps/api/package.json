{
  "name": "@michi-no-eki/api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "build": "wrangler deploy --dry-run --outdir=dist/worker",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply michi-no-eki-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply michi-no-eki-db --remote",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "hono": "catalog:"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "catalog:",
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "wrangler": "catalog:"
  }
}
